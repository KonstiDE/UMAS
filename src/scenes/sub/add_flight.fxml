<DialogPane prefHeight="674.0" prefWidth="785.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <content>
      <AnchorPane prefWidth="785.0">
         <children>
            <VBox prefHeight="648.0" prefWidth="750.0" spacing="8.0">
               <children>
                  <HBox prefWidth="200.0">
                     <children>
                        <Label text="Add Flight">
                           <font>
                              <Font size="16.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <Separator prefWidth="200.0">
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </Separator>
                  <GridPane prefHeight="591.0" prefWidth="726.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="476.0" minWidth="10.0" prefWidth="172.0" />
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="559.0" minWidth="10.0" prefWidth="554.0" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints maxHeight="-Infinity" minHeight="0.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" minHeight="0.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" minHeight="0.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" minHeight="10.0" prefHeight="100.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="-Infinity" minHeight="4.0" prefHeight="100.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="55.0" minHeight="0.0" prefHeight="34.0" vgrow="SOMETIMES" />
                     </rowConstraints>
                     <children>
                        <Label alignment="CENTER" text="Flight Date" textAlignment="CENTER">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>
                        <DatePicker id="addflight.date" prefWidth="191.0" GridPane.columnIndex="1" />
                        <Label text="Location" GridPane.rowIndex="1" />
                        <TextField id="addflight.location" text="Zugspitze" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="AOI" GridPane.rowIndex="2" />
                        <TextField id="addflight.aoi" text="West" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label text="Pilot" GridPane.rowIndex="3" />
                        <TextField id="addflight.pilot" text="ER" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <Label text="CoPilot" GridPane.rowIndex="4" />
                        <TextField id="addflight.copilot" text="KM" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        <Label text="UAV" GridPane.rowIndex="5" />
                        <ComboBox id="addflight.uav" prefWidth="150.0" promptText="Select UAV" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                        <Label text="Sensor" GridPane.rowIndex="6" />
                        <ComboBox id="addflight.sensor" prefWidth="150.0" promptText="Select Sensor" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                        <Label text="Image types captured" GridPane.rowIndex="7" />
                        <CheckComboBox id="addflight.imagetypes" prefHeight="26.0" prefWidth="152.0" showCheckedCount="true" title="Select" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                        <Label text="Image folder paths" GridPane.rowIndex="8" />
                        <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="554.0" spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="8">
                           <children>
                              <Button id="addflight.browse" mnemonicParsing="false" text="Browse" />
                              <TreeView id="addflight.flightdirs" prefHeight="92.0" prefWidth="468.0">
                                 <HBox.margin>
                                    <Insets top="4.0" />
                                 </HBox.margin>
                              </TreeView>
                           </children>
                        </HBox>
                        <Label text="Calibration folder paths" GridPane.rowIndex="9" />
                        <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="9">
                           <children>
                              <Button id="addflight.browsecalib" mnemonicParsing="false" text="Browse" />
                              <TreeView id="addflight.calibdirs" prefHeight="92.0" prefWidth="468.0">
                                 <HBox.margin>
                                    <Insets bottom="4.0" top="4.0" />
                                 </HBox.margin>
                              </TreeView>
                           </children>
                        </HBox>
                        <Label text="Notes" GridPane.rowIndex="10" />
                        <TextArea id="addflight.notes" prefHeight="134.0" prefWidth="554.0" text="Windigo" GridPane.columnIndex="1" GridPane.rowIndex="10" />
                     </children>
                  </GridPane>
               </children>
               <padding>
                  <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
               </padding>
            </VBox>
         </children>
      </AnchorPane>
   </content>
   <buttonTypes>
      <ButtonType fx:constant="CANCEL" />
      <ButtonType fx:constant="FINISH" />
   </buttonTypes>
</DialogPane>
